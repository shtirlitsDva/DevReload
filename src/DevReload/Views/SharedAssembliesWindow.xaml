<Window x:Class="DevReload.Views.SharedAssembliesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shared Assemblies"
        Width="420" Height="500"
        WindowStartupLocation="CenterScreen"
        Background="#3B4453">
    <Window.Resources>
        <SolidColorBrush x:Key="FgBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#A0AEC0"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2D3442"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#63B3ED"/>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Select assemblies to load into the default ALC"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="12" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="(required for WPF XAML-referenced NuGets like OxyPlot)"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="11" FontStyle="Italic" Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Cancel" Padding="12,6"
                    Background="{StaticResource SurfaceBrush}"
                    Foreground="{StaticResource FgBrush}"
                    BorderThickness="0" Cursor="Hand"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save" Padding="12,6"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    Command="{Binding SaveCommand}"
                    Click="Save_Click"/>
        </StackPanel>

        <!-- Assembly list -->
        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="4" Padding="4">
            <ListBox ItemsSource="{Binding Assemblies}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected}"
                                  Content="{Binding Name}"
                                  Foreground="{StaticResource FgBrush}"
                                  FontSize="12" Margin="4,3"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </DockPanel>
</Window>

<UserControl x:Class="DevReload.Views.DevReloadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DevReload.ViewModels"
             Background="#3B4453">
    <UserControl.Resources>
        <!-- Colors -->
        <Color x:Key="BgColor">#3B4453</Color>
        <Color x:Key="SurfaceColor">#2D3442</Color>
        <Color x:Key="AccentColor">#63B3ED</Color>
        <Color x:Key="AccentHoverColor">#4299E1</Color>
        <Color x:Key="DangerColor">#E53E3E</Color>
        <Color x:Key="DangerHoverColor">#C53030</Color>
        <Color x:Key="SuccessColor">#48BB78</Color>
        <Color x:Key="FgColor">#E2E8F0</Color>
        <Color x:Key="MutedColor">#A0AEC0</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="FgBrush" Color="{StaticResource FgColor}"/>
        <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Base button style -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SurfaceBtn" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="BorderBrush" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="{StaticResource FgBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Dark ComboBox toggle button -->
        <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="#4A5568" BorderThickness="1"
                        CornerRadius="4"/>
                <Border Grid.Column="0" Background="Transparent"
                        CornerRadius="4,0,0,4" Margin="1"/>
                <!-- Arrow -->
                <Path x:Name="Arrow" Grid.Column="1"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      Fill="{StaticResource MutedBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush"
                            Value="{StaticResource AccentBrush}"/>
                    <Setter TargetName="Arrow" Property="Fill"
                            Value="{StaticResource FgBrush}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush"
                            Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Dark ComboBox style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource DarkComboBoxToggleButton}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,2,24,2"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#1A202C"
                                            BorderBrush="#4A5568"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Margin="0,1,0,0"/>
                                    <ScrollViewer Margin="2,3" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBoxItem style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2D3748"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2B4C7E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ── Bottom toolbar ────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SurfaceBtn}"
                        Content="Settings"
                        Command="{Binding SettingsCommand}"
                        Margin="0,0,8,0"
                        ToolTip="Configure NSLOAD CSV path"/>
                <Button Style="{StaticResource AccentBtn}"
                        Content="+ Add Plugin"
                        Command="{Binding ShowAddPluginCommand}"
                        Margin="0,0,8,0"/>
                <Button Style="{StaticResource SurfaceBtn}"
                        Content="Reload Config"
                        Command="{Binding ReloadConfigCommand}"/>
            </StackPanel>
        </Border>

        <!-- ── Add Plugin form (collapsed by default) ────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource SurfaceBrush}"
                Padding="12" Margin="0,0,0,1"
                Visibility="{Binding IsAddingPlugin, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Add New Plugin" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource FgBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="Project" Foreground="{StaticResource MutedBrush}"
                           FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewPluginName, Mode=OneWay}"
                         IsReadOnly="True" Opacity="0.7"
                         Margin="0,0,0,6"/>

                <TextBlock Text="Command Prefix (default: Name)"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewPluginPrefix, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <CheckBox Content="Load on Startup"
                          IsChecked="{Binding NewPluginLoadOnStartup}"
                          Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SurfaceBtn}" Content="Cancel"
                            Command="{Binding CancelAddPluginCommand}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource AccentBtn}" Content="Add"
                            Command="{Binding ConfirmAddPluginCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Main content ──────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="20">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPlugins}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="No plugins configured"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="16" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Click 'Add Plugin' below to get started."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Plugin list -->
                <ItemsControl ItemsSource="{Binding Plugins}"
                              Visibility="{Binding HasPlugins, Converter={StaticResource BoolToVis}}"
                              Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PluginItemViewModel}">
                            <Border Background="{StaticResource SurfaceBrush}"
                                    CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Name + status + worktree + remove -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                        <!-- Remove button -->
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource DangerBtn}"
                                                Content="X" FontSize="10"
                                                Command="{Binding DataContext.RemovePluginCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Name}"
                                                ToolTip="Remove plugin"/>

                                        <!-- Worktree selector -->
                                        <ComboBox DockPanel.Dock="Right"
                                                  ItemsSource="{Binding Worktrees}"
                                                  SelectedItem="{Binding SelectedWorktree}"
                                                  DropDownOpened="WorktreeComboBox_DropDownOpened"
                                                  FontSize="11"
                                                  Margin="8,0,4,0"
                                                  MinWidth="80"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Select worktree to build from">
                                            <ComboBox.Style>
                                                <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBox}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Worktrees.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.Style>
                                        </ComboBox>

                                        <!-- Status circle -->
                                        <Ellipse DockPanel.Dock="Left"
                                                 Width="10" Height="10"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource MutedBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLoaded}" Value="True">
                                                            <Setter Property="Fill"
                                                                    Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>

                                        <!-- Name + prefix + status -->
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource FgBrush}"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11" Margin="8,0,0,0"
                                                       VerticalAlignment="Center">
                                                <Run Text="["/><Run Text="{Binding CommandPrefix, Mode=OneWay}"/><Run Text="]"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       FontSize="11" Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Row 1: Actions -->
                                    <DockPanel Grid.Row="1">
                                        <!-- Load on Startup checkbox -->
                                        <CheckBox DockPanel.Dock="Right"
                                                  Content="Auto-load"
                                                  FontSize="11"
                                                  IsChecked="{Binding LoadOnStartup}"
                                                  VerticalAlignment="Center"
                                                  Margin="8,0,0,0"/>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Build config toggle -->
                                            <ToggleButton IsChecked="{Binding IsReleaseBuild}"
                                                          FontSize="10" FontWeight="Bold"
                                                          Padding="6,3" Margin="0,0,4,0"
                                                          Cursor="Hand"
                                                          ToolTip="Toggle Debug / Release build">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border x:Name="border"
                                                                            CornerRadius="4"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <TextBlock x:Name="label"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   FontWeight="Bold"
                                                                                   FontSize="10"
                                                                                   Foreground="White"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="False">
                                                                            <Setter TargetName="border"
                                                                                    Property="Background"
                                                                                    Value="{StaticResource SuccessBrush}"/>
                                                                            <Setter TargetName="label"
                                                                                    Property="Text" Value="DBG"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="border"
                                                                                    Property="Background"
                                                                                    Value="{StaticResource DangerBrush}"/>
                                                                            <Setter TargetName="label"
                                                                                    Property="Text" Value="REL"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="border"
                                                                                    Property="Opacity" Value="0.85"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <Button Style="{StaticResource AccentBtn}"
                                                    Content="Reload" FontSize="11"
                                                    Padding="8,3" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.DevReloadPluginCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"/>
                                            <Button Style="{StaticResource DangerBtn}"
                                                    Content="Unload" FontSize="11"
                                                    Padding="8,3" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.UnloadPluginCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    IsEnabled="{Binding IsLoaded}"/>
                                            <Button Style="{StaticResource SurfaceBtn}"
                                                    Content="Shared" FontSize="11"
                                                    Padding="8,3" Margin="0,0,4,0"
                                                    Command="{Binding DataContext.SharedAssembliesCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    ToolTip="Configure shared assemblies for WPF XAML"/>
                                            <Button Style="{StaticResource SurfaceBtn}"
                                                    Content="Push" FontSize="11"
                                                    Padding="8,3"
                                                    Command="{Binding DataContext.PushToProductionCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    ToolTip="Push SharedAssemblies config to production"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>

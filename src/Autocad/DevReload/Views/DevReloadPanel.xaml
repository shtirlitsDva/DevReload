<UserControl x:Class="DevReload.Views.DevReloadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DevReload.ViewModels"
             Style="{DynamicResource RootPanel}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Relative path (NOT pack://...;component) — required for the
                     dictionary to resolve when the assembly is loaded by AutoCAD. -->
                <ResourceDictionary Source="../Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel>
        <!-- ── Bottom toolbar ────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource ToolbarBar}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SurfaceBtn}"
                        Content="Settings"
                        Command="{Binding SettingsCommand}"
                        Margin="0,0,8,0"
                        ToolTip="Configure NSLOAD CSV path"/>
                <Button Style="{StaticResource AccentBtn}"
                        Content="+ Add Plugin"
                        Command="{Binding ShowAddPluginCommand}"
                        Margin="0,0,8,0"/>
                <Button Style="{StaticResource SurfaceBtn}"
                        Content="Reload Config"
                        Command="{Binding ReloadConfigCommand}"/>
            </StackPanel>
        </Border>

        <!-- ── Add Plugin form (collapsed by default) ────────── -->
        <Border DockPanel.Dock="Bottom"
                Style="{StaticResource FormPanel}"
                Margin="0,0,0,1"
                Visibility="{Binding IsAddingPlugin, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Add New Plugin"
                           Style="{StaticResource SectionTitle}" Margin="0,0,0,8"/>

                <TextBlock Text="Project"
                           Style="{StaticResource Caption}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewPluginName, Mode=OneWay}"
                         Style="{StaticResource ReadOnlyField}"
                         IsReadOnly="True"
                         Margin="0,0,0,6"/>

                <TextBlock Text="Command Prefix (default: Name)"
                           Style="{StaticResource Caption}" Margin="0,0,0,2"/>
                <TextBox Text="{Binding NewPluginPrefix, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,8"/>

                <CheckBox Content="Load on Startup"
                          IsChecked="{Binding NewPluginLoadOnStartup}"
                          Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SurfaceBtn}" Content="Cancel"
                            Command="{Binding CancelAddPluginCommand}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource AccentBtn}" Content="Add"
                            Command="{Binding ConfirmAddPluginCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Main content ──────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Empty state -->
                <StackPanel Style="{StaticResource EmptyStatePanel}"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="20">
                    <TextBlock Text="No plugins configured"
                               Style="{StaticResource EmptyTitle}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Click 'Add Plugin' below to get started."
                               Style="{StaticResource Hint}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Plugin list -->
                <ItemsControl ItemsSource="{Binding Plugins}"
                              Visibility="{Binding HasPlugins, Converter={StaticResource BoolToVis}}"
                              Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:PluginItemViewModel}">
                            <Border Style="{StaticResource PluginCard}" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Name + status + worktree + remove -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                        <!-- Remove button -->
                                        <Button DockPanel.Dock="Right"
                                                Style="{StaticResource IconDangerBtn}"
                                                Content="X"
                                                Command="{Binding DataContext.RemovePluginCommand,
                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding Name}"
                                                ToolTip="Remove plugin"/>

                                        <!-- Worktree selector -->
                                        <ComboBox DockPanel.Dock="Right"
                                                  Style="{StaticResource WorktreeCombo}"
                                                  ItemsSource="{Binding Worktrees}"
                                                  SelectedItem="{Binding SelectedWorktree}"
                                                  DropDownOpened="WorktreeComboBox_DropDownOpened"
                                                  Margin="8,0,4,0"
                                                  MinWidth="80"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Select worktree to build from"/>

                                        <!-- Status circle -->
                                        <Ellipse DockPanel.Dock="Left"
                                                 Style="{StaticResource StatusDot}"
                                                 Width="10" Height="10"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>

                                        <!-- Name + prefix + status -->
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource PluginName}"/>
                                            <TextBlock Style="{StaticResource Caption}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center">
                                                <Run Text="["/><Run Text="{Binding CommandPrefix, Mode=OneWay}"/><Run Text="]"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Status}"
                                                       Style="{StaticResource Caption}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Row 1: Actions -->
                                    <DockPanel Grid.Row="1">
                                        <!-- Load on Startup checkbox -->
                                        <CheckBox DockPanel.Dock="Right"
                                                  Style="{StaticResource SmallCheckBox}"
                                                  Content="Auto-load"
                                                  IsChecked="{Binding LoadOnStartup}"
                                                  VerticalAlignment="Center"
                                                  Margin="8,0,0,0"/>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Build config toggle (DBG / REL) -->
                                            <ToggleButton IsChecked="{Binding IsReleaseBuild}"
                                                          Style="{StaticResource BuildConfigToggle}"
                                                          Margin="0,0,4,0"
                                                          ToolTip="Toggle Debug / Release build"/>

                                            <!-- Reload split-button: click = Reload (build+load);
                                                 ▾ flyout = Build only (build, no load) -->
                                            <Border Style="{StaticResource SplitBar}" Margin="0,0,4,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Style="{StaticResource SplitMainBtn}"
                                                            Content="Reload"
                                                            Command="{Binding DataContext.DevReloadPluginCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Name}"
                                                            ToolTip="Build and reload the plugin"/>
                                                    <ToggleButton x:Name="ReloadFlyout"
                                                                  Style="{StaticResource SplitArrowToggle}"
                                                                  Content="▾"
                                                                  ToolTip="More build actions"/>
                                                    <Popup PlacementTarget="{Binding ElementName=ReloadFlyout}"
                                                           Placement="Bottom" StaysOpen="False"
                                                           AllowsTransparency="True"
                                                           IsOpen="{Binding IsChecked, ElementName=ReloadFlyout, Mode=TwoWay}">
                                                        <Border Style="{StaticResource FlyoutPanel}" Margin="0,2,0,0">
                                                            <Button Style="{StaticResource RowSurfaceBtn}"
                                                                    Content="Build only"
                                                                    Click="BuildOnlyFlyout_Click"
                                                                    ToolTip="Build without loading — produces the DLLs so Shared can be configured for this branch"/>
                                                        </Border>
                                                    </Popup>
                                                </StackPanel>
                                            </Border>

                                            <Button Style="{StaticResource RowDangerBtn}"
                                                    Content="Unload"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.UnloadPluginCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    IsEnabled="{Binding IsLoaded}"/>
                                            <Button Style="{StaticResource SharedBtn}"
                                                    Content="Shared"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.SharedAssembliesCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    ToolTip="Configure shared assemblies for WPF XAML (green = config present for this branch/build)"/>
                                            <Button Style="{StaticResource RowSurfaceBtn}"
                                                    Content="Push"
                                                    Command="{Binding DataContext.PushToProductionCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    ToolTip="Push SharedAssemblies config to production"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>

<Window x:Class="DevReload.Views.SharedAssembliesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Shared Assemblies"
        Width="520" Height="540"
        WindowStartupLocation="CenterScreen"
        Style="{DynamicResource RootWindow}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Relative path (NOT pack://...;component) — required for the
                     dictionary to resolve when loaded by AutoCAD. -->
                <ResourceDictionary Source="../Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="12">
        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Select assemblies to load into the default ALC"
                   Style="{StaticResource Hint}" Margin="0,0,0,10"/>

        <!-- Copy-from row -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8"
              Visibility="{Binding HasSources, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Copy config from:"
                       Style="{StaticResource Caption}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1"
                      Style="{StaticResource DarkComboBox}"
                      ItemsSource="{Binding Sources}"
                      SelectedItem="{Binding SelectedSource}"
                      VerticalAlignment="Center"/>
            <Button Grid.Column="2"
                    Style="{StaticResource RowSurfaceBtn}"
                    Content="Copy"
                    Margin="8,0,0,0"
                    Command="{Binding CopyFromCommand}"
                    ToolTip="Copy the shared-assembly selection from the chosen branch (DLLs missing here are skipped)"/>
        </Grid>

        <!-- Copy result / warning -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding CopyStatus}"
                   Style="{StaticResource Caption}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Visibility="{Binding HasCopyStatus, Converter={StaticResource BoolToVis}}"/>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource DialogSurfaceBtn}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Save"
                    Style="{StaticResource DialogAccentBtn}"
                    Command="{Binding SaveCommand}"
                    Click="Save_Click"/>
        </StackPanel>

        <!-- Assembly list -->
        <Border Style="{StaticResource ListPanel}">
            <ListBox ItemsSource="{Binding Assemblies}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected}"
                                      Content="{Binding Name}"
                                      Margin="4,3"/>
                            <CheckBox Grid.Column="1"
                                      Style="{StaticResource CaptionCheckBox}"
                                      IsChecked="{Binding IsMixedMode}"
                                      Content="C++/CLI"
                                      Margin="4,3"
                                      IsEnabled="{Binding CanEnableMixedMode}"
                                      ToolTip="Mark as mixed-mode (C++/CLI) assembly — auto-creates runtimeconfig.json"/>
                            <CheckBox Grid.Column="2"
                                      Style="{StaticResource CaptionCheckBox}"
                                      IsChecked="{Binding IsStreamed}"
                                      Content="Stream (no lock)"
                                      Margin="4,3"
                                      IsEnabled="{Binding CanEnableStreamed}"
                                      ToolTip="Load via Assembly.Load(byte[]) — releases the DLL file lock so the project can be rebuilt without restarting AutoCAD. The running image stays loaded; restart AutoCAD to pick up code changes."/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</Window>

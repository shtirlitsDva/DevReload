<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net48</TargetFramework>
		<SupportedOSPlatformVersion Condition="'$(TargetFramework)' == 'net48'"></SupportedOSPlatformVersion>
		<AssemblyName>RevitDevReload.R23</AssemblyName>
		<RootNamespace>RevitDevReload</RootNamespace>
		<OutputType>Library</OutputType>
		<GenerateAssemblyInfo>true</GenerateAssemblyInfo>
		<NoWarn>$(NoWarn);CA1416;MSB3277</NoWarn>
		<CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
		<LangVersion>latest</LangVersion>
		<DefineConstants>$(DefineConstants);REVIT2023</DefineConstants>
		<!-- Revit 2023 installation; override via -p:RevitPath2023=... -->
		<RevitPath2023 Condition="'$(RevitPath2023)' == ''">C:\Program Files\Autodesk\Revit 2023</RevitPath2023>
	</PropertyGroup>
	<PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
		<OutputPath>bin\Debug\</OutputPath>
		<DebugType>full</DebugType>
	</PropertyGroup>
	<PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x64'">
		<OutputPath>bin\Release\</OutputPath>
		<DebugType>full</DebugType>
	</PropertyGroup>
	<ItemGroup>
		<Reference Include="RevitAPI">
			<HintPath>$(RevitPath2023)\RevitAPI.dll</HintPath>
			<Private>False</Private>
		</Reference>
		<Reference Include="RevitAPIUI">
			<HintPath>$(RevitPath2023)\RevitAPIUI.dll</HintPath>
			<Private>False</Private>
		</Reference>
		<Reference Include="AdWindows">
			<HintPath>$(RevitPath2023)\AdWindows.dll</HintPath>
			<Private>False</Private>
		</Reference>
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
		<PackageReference Include="ricaun.Revit.UI" Version="0.9.0" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="System.Text.Json" Version="8.0.5" />
		<Reference Include="System.Net.Http" />
	</ItemGroup>
	<Import Project="..\RevitDevReload.Shared\RevitDevReload.Shared.projitems" Label="Shared" />
	<Import Project="..\..\Shared\DevReload.BuildCore\DevReload.BuildCore.projitems" Label="Shared" />
	<ItemGroup>
		<!-- Only the shared theme from WpfSHARED — the grid forms there use
		     net5+ APIs and nothing in the Revit host needs them. -->
		<Page Include="..\..\Shared\WpfSHARED\Themes\Theme.xaml">
			<Link>Themes\Theme.xaml</Link>
			<Generator>MSBuild:Compile</Generator>
		</Page>
	</ItemGroup>
</Project>
